<?xml version="1.0" ?>

<robot name="cleanbit_tracked_robot">

  <!-- ========================================================= -->
  <!-- MATERIALS -->
  <!-- ========================================================= -->

  <material name="body_material">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>

  <material name="wheel_material">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="track_material">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <material name="laser_material">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>

  <material name="front_marker_material">
    <color rgba="0.0 0.8 1.0 1.0"/>
  </material>


  <!-- ========================================================= -->
  <!-- BODY LINK -->
  <!-- Convenzione ROS:
       X = avanti
       Y = sinistra
       Z = alto
  ========================================================== -->

  <link name="body_link">

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.1"/>
      </geometry>
      <material name="body_material"/>
    </visual>

    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="10"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.98125" ixy="0.0" ixz="0.0"
        iyy="2.55125" iyz="0.0"
        izz="3.33625"/>
    </inertial>

  </link>


  <!-- ========================================================= -->
  <!-- FRONT MARKER -->
  <!-- Serve solo per capire visivamente dove sta il davanti.
       È messo sul lato +X.
  ========================================================== -->

  <link name="front_marker_link">

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.22 0.03"/>
      </geometry>
      <material name="front_marker_material"/>
    </visual>

  </link>

  <joint name="front_marker_joint" type="fixed">
    <parent link="body_link"/>
    <child link="front_marker_link"/>
    <origin rpy="0 0 0" xyz="0.27 0 0.03"/>
  </joint>


  <!-- ========================================================= -->
  <!-- LEFT DRIVE WHEEL -->
  <!-- Ruota motrice sinistra davanti: X positivo, Y positivo -->
  <!-- Questa è quella usata dal diff drive -->
  <!-- ========================================================= -->

  <link name="left_wheel_link">

    <visual>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>

    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2"/>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.0038288" ixy="0.0" ixz="0.0"
        iyy="0.0038288" iyz="0.0"
        izz="0.0070685"/>
    </inertial>

  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="left_wheel_link"/>

    <!-- DAVANTI: x positivo -->
    <origin rpy="0 0 0" xyz="0.15 0.175 -0.05"/>

    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>


  <!-- ========================================================= -->
  <!-- RIGHT DRIVE WHEEL -->
  <!-- Ruota motrice destra davanti: X positivo, Y negativo -->
  <!-- Questa è quella usata dal diff drive -->
  <!-- ========================================================= -->

  <link name="right_wheel_link">

    <visual>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>

    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2"/>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.0038288" ixy="0.0" ixz="0.0"
        iyy="0.0038288" iyz="0.0"
        izz="0.0070685"/>
    </inertial>

  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="right_wheel_link"/>

    <!-- DAVANTI: x positivo -->
    <origin rpy="0 0 0" xyz="0.15 -0.175 -0.05"/>

    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>


  <!-- ========================================================= -->
  <!-- REAR LEFT WHEEL VISUAL -->
  <!-- Ruota posteriore sinistra solo estetica -->
  <!-- ========================================================= -->

  <link name="rear_left_wheel_link">

    <visual>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>

    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.002" ixy="0.0" ixz="0.0"
        iyy="0.002" iyz="0.0"
        izz="0.004"/>
    </inertial>

  </link>

  <joint name="rear_left_wheel_joint" type="fixed">
    <parent link="body_link"/>
    <child link="rear_left_wheel_link"/>

    <!-- Dietro: x negativo -->
    <origin rpy="0 0 0" xyz="-0.15 0.175 -0.05"/>
  </joint>


  <!-- ========================================================= -->
  <!-- REAR RIGHT WHEEL VISUAL -->
  <!-- Ruota posteriore destra solo estetica -->
  <!-- ========================================================= -->

  <link name="rear_right_wheel_link">

    <visual>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>

    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.002" ixy="0.0" ixz="0.0"
        iyy="0.002" iyz="0.0"
        izz="0.004"/>
    </inertial>

  </link>

  <joint name="rear_right_wheel_joint" type="fixed">
    <parent link="body_link"/>
    <child link="rear_right_wheel_link"/>

    <!-- Dietro: x negativo -->
    <origin rpy="0 0 0" xyz="-0.15 -0.175 -0.05"/>
  </joint>


  <!-- ========================================================= -->
  <!-- LEFT TRACK VISUAL -->
  <!-- Cingolo sinistro estetico -->
  <!-- ========================================================= -->

  <link name="left_track_link">

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.42 0.055 0.045"/>
      </geometry>
      <material name="track_material"/>
    </visual>

    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.42 0.055 0.045"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>

  </link>

  <joint name="left_track_joint" type="fixed">
    <parent link="body_link"/>
    <child link="left_track_link"/>
    <origin rpy="0 0 0" xyz="0 0.175 -0.05"/>
  </joint>


  <!-- ========================================================= -->
  <!-- RIGHT TRACK VISUAL -->
  <!-- Cingolo destro estetico -->
  <!-- ========================================================= -->

  <link name="right_track_link">

    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.42 0.055 0.045"/>
      </geometry>
      <material name="track_material"/>
    </visual>

    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.42 0.055 0.045"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>

  </link>

  <joint name="right_track_joint" type="fixed">
    <parent link="body_link"/>
    <child link="right_track_link"/>
    <origin rpy="0 0 0" xyz="0 -0.175 -0.05"/>
  </joint>


  <!-- ========================================================= -->
  <!-- LIDAR -->
  <!-- Lidar davanti al robot.
       Il suo frame segue la convenzione:
       X = avanti
       Y = sinistra
       Z = alto
  ========================================================== -->

  <link name="laser_frame">

    <visual>
      <!-- cilindro verticale -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
      <material name="laser_material"/>
    </visual>

    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia
        ixx="0.001" ixy="0.0" ixz="0.0"
        iyy="0.001" iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="body_link"/>
    <child link="laser_frame"/>

    <!-- DAVANTI: x positivo -->
    <origin rpy="0 0 0" xyz="0.18 0 0.175"/>
  </joint>


  <!-- ========================================================= -->
  <!-- GAZEBO PARAMETERS -->
  <!-- Li lascio perché erano nel tuo file originale.
       Se usi solo RViz, questa parte non ti cambia nulla.
  ========================================================== -->

  <gazebo reference="body_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="rear_right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="rear_left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="left_track_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_track_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="laser_frame">
    <sensor name="laser_frame" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>200</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>


  <!-- ========================================================= -->
  <!-- GAZEBO PLUGINS -->
  <!-- Nota:
       Il plugin usa solo left_wheel_joint e right_wheel_joint.
       Le ruote posteriori e i cingoli sono visivi/fissi.
  ========================================================== -->

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">

      <right_joint>right_wheel_joint</right_joint>
      <left_joint>left_wheel_joint</left_joint>

      <wheel_separation>0.35</wheel_separation>
      <wheel_radius>0.1</wheel_radius>

      <max_linear_acceleration>10</max_linear_acceleration>
      <odom_publish_frequency>100</odom_publish_frequency>

      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>

      <odometry_frame>odom</odometry_frame>

      <!-- Ora uso body_link perché è il frame principale reale del tuo URDF -->
      <robot_base_frame>body_link</robot_base_frame>

    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>left_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>

<?xml version="1.0"?>

<robot name="spazzino" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ========================================================= -->
    <!-- Robot Parameters -->
    <!-- Convenzione ROS:
         X = avanti
         Y = sinistra
         Z = alto

         Davanti reale del robot = lato ruote motrici + lidar.
         Quindi ruote motrici e lidar stanno a X positivo.
    ========================================================== -->

    <xacro:property name="PI" value="3.14159265"/>

    <xacro:property name="body_length" value="0.24"/>
    <xacro:property name="body_width" value="0.2"/>
    <xacro:property name="body_height" value="0.165"/>
    <xacro:property name="body_density" value="7850.0"/>

    <xacro:property name="body_mass" value="${body_density * body_length * body_height * body_width}"/>
    <xacro:property name="body_inertia_x" value="${1.0/12.0 * body_mass * (body_height*body_height + body_width*body_width)}"/>
    <xacro:property name="body_inertia_y" value="${1.0/12.0 * body_mass * (body_length*body_length + body_height*body_height)}"/>
    <xacro:property name="body_inertia_z" value="${1.0/12.0 * body_mass * (body_length*body_length + body_width*body_width)}"/>

    <xacro:property name="wheel_radius" value="0.055"/>
    <xacro:property name="wheel_width" value="0.03"/>
    <xacro:property name="wheel_separation" value="${body_width + wheel_width}"/>
    <xacro:property name="wheel_offset" value="${body_length/2 - wheel_radius}"/>
    <xacro:property name="wheel_density" value="900"/>

    <xacro:property name="wheel_mass" value="${wheel_density * PI * wheel_radius * wheel_radius * wheel_width}"/>
    <xacro:property name="wheel_inertia_x" value="${1.0/12.0 * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
    <xacro:property name="wheel_inertia_y" value="${1.0/12.0 * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
    <xacro:property name="wheel_inertia_z" value="${1.0/2.0 * wheel_mass * wheel_radius * wheel_radius}"/>

    <xacro:property name="track_length" value="${body_length}"/>
    <xacro:property name="track_width" value="0.035"/>
    <xacro:property name="track_height" value="0.035"/>

    <xacro:property name="laser_radius" value="0.04"/>
    <xacro:property name="laser_height" value="0.035"/>

    <xacro:property name="max_linear_acceleration" value="10"/>


    <!-- ========================================================= -->
    <!-- Materials -->
    <!-- ========================================================= -->

    <material name="body_material">
        <color rgba="0.25 0.25 0.25 1.0"/>
    </material>

    <material name="wheel_material">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <material name="track_material">
        <color rgba="0.02 0.02 0.02 1.0"/>
    </material>

    <material name="laser_material">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>

    <material name="front_marker_material">
        <color rgba="0.0 0.8 1.0 1.0"/>
    </material>


    <!-- ========================================================= -->
    <!-- BASE LINK -->
    <!-- Frame principale ROS:
         X rosso = avanti reale
         Y verde = sinistra
         Z blu = alto
    ========================================================== -->

    <link name="base_link"/>


    <!-- ========================================================= -->
    <!-- BODY LINK -->
    <!-- Corpo del robot.
         NON viene più ruotato di 180 gradi.
    ========================================================== -->

    <link name="body_link">
        <visual>
            <origin xyz="0.0 0.0 0.027" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}"/>
            </geometry>
            <material name="body_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.027" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="10"/>
            <inertia
                ixx="${body_inertia_x}" ixy="0.0" ixz="0.0"
                iyy="${body_inertia_y}" iyz="0.0"
                izz="${body_inertia_z}"/>
            <origin xyz="0 0 0.027" rpy="0 0 0"/>
        </inertial>
    </link>


    <!-- ========================================================= -->
    <!-- BASE TO BODY JOINT -->
    <!-- Correzione importante:
         prima era rpy="0 0 ${PI}", e quello girava tutto di 180°.
         Ora è zero.
    ========================================================== -->

    <joint name="base_to_body_joint" type="fixed">
        <parent link="base_link"/>
        <child link="body_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- BASE FOOTPRINT -->
    <!-- Frame a terra collegato a base_link.
    ========================================================== -->

    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- FRONT MARKER -->
    <!-- Marker visivo sul davanti reale, cioè lato +X.
    ========================================================== -->

    <link name="front_marker_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.14 0.025"/>
            </geometry>
            <material name="front_marker_material"/>
        </visual>
    </link>

    <joint name="front_marker_joint" type="fixed">
        <parent link="body_link"/>
        <child link="front_marker_link"/>
        <origin xyz="${body_length/2 + 0.012} 0 0.11" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- LEFT DRIVE WHEEL -->
    <!-- Ruota motrice sinistra DAVANTI.
         X positivo = davanti.
         Y positivo = sinistra.
    ========================================================== -->

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${wheel_inertia_x}" ixy="0.0" ixz="0.0"
                iyy="${wheel_inertia_y}" iyz="0.0"
                izz="${wheel_inertia_z}"/>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${wheel_offset} ${wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="100" velocity="10.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>


    <!-- ========================================================= -->
    <!-- RIGHT DRIVE WHEEL -->
    <!-- Ruota motrice destra DAVANTI.
         X positivo = davanti.
         Y negativo = destra.
    ========================================================== -->

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${wheel_inertia_x}" ixy="0.0" ixz="0.0"
                iyy="${wheel_inertia_y}" iyz="0.0"
                izz="${wheel_inertia_z}"/>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="body_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${wheel_offset} ${-wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="100" velocity="10.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>


    <!-- ========================================================= -->
    <!-- REAR LEFT WHEEL -->
    <!-- Ruota posteriore sinistra, fissa/visiva.
    ========================================================== -->

    <link name="rear_left_wheel_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${wheel_inertia_x}" ixy="0.0" ixz="0.0"
                iyy="${wheel_inertia_y}" iyz="0.0"
                izz="${wheel_inertia_z}"/>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
        </inertial>
    </link>

    <joint name="rear_left_wheel_joint" type="fixed">
        <parent link="body_link"/>
        <child link="rear_left_wheel_link"/>
        <origin xyz="-${wheel_offset} ${wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- REAR RIGHT WHEEL -->
    <!-- Ruota posteriore destra, fissa/visiva.
    ========================================================== -->

    <link name="rear_right_wheel_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${wheel_inertia_x}" ixy="0.0" ixz="0.0"
                iyy="${wheel_inertia_y}" iyz="0.0"
                izz="${wheel_inertia_z}"/>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
        </inertial>
    </link>

    <joint name="rear_right_wheel_joint" type="fixed">
        <parent link="body_link"/>
        <child link="rear_right_wheel_link"/>
        <origin xyz="-${wheel_offset} ${-wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- LEFT TRACK VISUAL -->
    <!-- Cingolo sinistro visivo.
    ========================================================== -->

    <link name="left_track_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}"/>
            </geometry>
            <material name="track_material"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <inertia
                ixx="0.001" ixy="0.0" ixz="0.0"
                iyy="0.001" iyz="0.0"
                izz="0.001"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </inertial>
    </link>

    <joint name="left_track_joint" type="fixed">
        <parent link="body_link"/>
        <child link="left_track_link"/>
        <origin xyz="0 ${wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- RIGHT TRACK VISUAL -->
    <!-- Cingolo destro visivo.
    ========================================================== -->

    <link name="right_track_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}"/>
            </geometry>
            <material name="track_material"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${track_length} ${track_width} ${track_height}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <inertia
                ixx="0.001" ixy="0.0" ixz="0.0"
                iyy="0.001" iyz="0.0"
                izz="0.001"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </inertial>
    </link>

    <joint name="right_track_joint" type="fixed">
        <parent link="body_link"/>
        <child link="right_track_link"/>
        <origin xyz="0 ${-wheel_separation/2} -${wheel_radius/2}" rpy="0 0 0"/>
    </joint>


    <!-- ========================================================= -->
    <!-- LIDAR -->
    <!-- Lidar davanti: X positivo.
         Se il LaserScan risulta girato di 180°, ruota SOLO questo joint:
         rpy="0 0 ${PI}"
    ========================================================== -->

    <link name="laser_frame">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${laser_radius}" length="${laser_height}"/>
            </geometry>
            <material name="laser_material"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${laser_radius}" length="${laser_height}"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.2"/>
            <inertia
                ixx="0.001" ixy="0.0" ixz="0.0"
                iyy="0.001" iyz="0.0"
                izz="0.001"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </inertial>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="body_link"/>
        <child link="laser_frame"/>
        <origin xyz="${body_length/2 - 0.03} 0 0.125" rpy="0 0 0"/>
    </joint>

</robot>
